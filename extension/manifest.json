{
  "manifest_version": 3,
  "name": "Island Tab Manager",
  "version": "1.0.0",
  "description": "Cozy island-themed new-tab dashboard. Groups your tabs by domain, tracks your tab health score, and keeps your to-do list tidy. No server, no account needed.",
  "permissions": ["tabs", "activeTab", "storage", "geolocation", "tabGroups"],
  "host_permissions": ["https://api.open-meteo.com/*"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Out",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
